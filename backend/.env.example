# Server
PORT=3001
NODE_ENV=development

# JWT — REQUIRED in production (server refuses to start without it)
JWT_SECRET=change-me

# Default execution mode: cli-full | cli-lite | api | apsf-run
EXECUTION_MODE=cli-full

# Real APSF Framework integration (apsf-run mode).
# Point at your ai-problem-solving-framework checkout (must contain runs/).
# Requires the `apsf` CLI on PATH (pip install -e <framework>).
# APSF_ROOT=/path/to/ai-problem-solving-framework
# APSF_BIN=apsf

# Permission mode passed to claude CLI for BUILD phases (default: acceptEdits)
# APSF_PERMISSION_MODE=acceptEdits

# Where cli-full mode saves artifacts (default: ./runs)
# RUNS_DIR=./runs

# NOTE: API keys are NOT required — AI CLIs (claude/codex) use their own
# session auth. Keys set here are deliberately stripped before spawning CLIs.
