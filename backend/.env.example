# Server
PORT=3001
NODE_ENV=development

# JWT — REQUIRED in production (server refuses to start without it)
JWT_SECRET=change-me

# Default execution mode: cli-full | cli-lite | api | apsf-run
EXECUTION_MODE=cli-full

# Real APSF Framework integration (apsf-run mode).
# Point at any workspace directory containing runs/ (an empty runs/ works —
# templates and specialists ship with Explorer). No python required.
# APSF_ROOT=/path/to/workspace

# Permission mode passed to claude CLI for BUILD phases (default: acceptEdits)
# APSF_PERMISSION_MODE=acceptEdits

# Where cli-full mode saves artifacts (default: ./runs)
# RUNS_DIR=./runs

# Authentication mode: demo (default) | basic
# - demo: /api/auth/login accepts ANY credentials and issues a real JWT.
#   Fine for local demos; the server warns loudly if used in production.
# - basic: credentials are checked against USERS_FILE (email -> bcrypt hash).
#   Wrong credentials get 401; /api/auth/register is disabled (403).
#   Generate a hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# AUTH_MODE=demo
# USERS_FILE=/path/to/users.json

# NOTE: API keys are NOT required — AI CLIs (claude/codex) use their own
# session auth. Keys set here are deliberately stripped before spawning CLIs.
